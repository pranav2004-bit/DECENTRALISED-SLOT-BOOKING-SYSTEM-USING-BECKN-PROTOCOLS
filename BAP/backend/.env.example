# BAP Backend — environment configuration template. Copy to .env and fill with real values (never commit .env).

# --- App ---
DJANGO_ENV=local
DJANGO_SECRET_KEY=changeme-generate-a-real-secret
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,bap-backend

# --- Database ---
# local-dev-only placeholder password, not a real credential
DATABASE_URL=postgres://bap:bap@bap-db:5432/bap
DB_CONN_MAX_AGE=60
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# --- Cache / sessions ---
REDIS_URL=redis://bap-cache:6379/0

# --- Registry / network identity ---
REGISTRY_BASE_URL=http://registry:8000
GATEWAY_BASE_URL=http://beckn-gateway:8000
SUBSCRIBER_ID=changeme.bap.example.com
UNIQUE_KEY_ID=changeme-uuid
# The BAP's own real, publicly reachable HTTPS URL — Registry dispatches the
# on_subscribe challenge here and fetches /ondc-site-verification.html from here.
# Must be a real domain in staging/preprod/prod (Phase 3 onboarding); local Docker
# dev can point this at the bap-backend service if testing onboarding against a
# locally-run Registry that can reach it.
SUBSCRIBER_URL=
BAP_SIGNING_PRIVATE_KEY_PATH=/app/data/secrets/bap_signing_key
BAP_ENCRYPTION_PRIVATE_KEY_PATH=/app/data/secrets/bap_encryption_key
ON_SUBSCRIBE_CALLBACK_PATH=/on_subscribe

# --- Payment Gateway (per BAP_details_v1.1.md §5) ---
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY_PATH=/run/secrets/payment_gateway_key

# --- HTTP client resilience defaults ---
HTTP_CLIENT_TIMEOUT_MS=5000
HTTP_CLIENT_MAX_RETRIES=3
HTTP_CLIENT_CIRCUIT_BREAKER_THRESHOLD=5

# --- Internal event bus (EDA, per BAP_details_v1.1.md §9) ---
EVENT_BUS_URL=redis://bap-cache:6379/1
EVENT_BUS_DLQ_NAME=bap-internal-dlq

# --- CORS (BAP web app origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
