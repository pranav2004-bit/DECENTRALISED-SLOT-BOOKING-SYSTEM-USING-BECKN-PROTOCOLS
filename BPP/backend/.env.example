# BPP Backend — environment configuration template. Copy to .env and fill with real values (never commit .env).

# --- App ---
DJANGO_ENV=local
DJANGO_SECRET_KEY=changeme-generate-a-real-secret
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,bpp-backend

# --- Database ---
# local-dev-only placeholder password, not a real credential
DATABASE_URL=postgres://bpp:bpp@bpp-db:5432/bpp
DB_CONN_MAX_AGE=60
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# --- Cache / sessions ---
REDIS_URL=redis://bpp-cache:6379/0

# --- Registry / network identity ---
REGISTRY_BASE_URL=http://registry:8000
GATEWAY_BASE_URL=http://beckn-gateway:8000
SUBSCRIBER_ID=changeme.bpp.example.com
UNIQUE_KEY_ID=changeme-uuid
# The BPP's own real, publicly reachable HTTPS URL — see BAP/backend/.env.example's
# SUBSCRIBER_URL comment for the full rationale (identical here).
SUBSCRIBER_URL=
BPP_SIGNING_PRIVATE_KEY_PATH=/app/data/secrets/bpp_signing_key
BPP_ENCRYPTION_PRIVATE_KEY_PATH=/app/data/secrets/bpp_encryption_key
ON_SUBSCRIBE_CALLBACK_PATH=/on_subscribe

# --- Service domains (per BPP_details_v1.1.md — see protocol_compliance_notes_v1.1.md "Remaining
# Open Items" for the full research trail). Healthcare/Automotive likely live under ONDC's
# "Services" vertical (ONDC:SRV##, per ONDC-SRV-Specifications) rather than Retail or Mobility —
# narrowed but not confirmed; do not guess the numeric code, confirm before Phase 3 onboarding. ---
DOMAIN_HEALTHCARE=CONFIRM_BEFORE_USE
DOMAIN_AUTOMOTIVE=CONFIRM_BEFORE_USE
DOMAIN_BEAUTY=ONDC:RET13

# --- HTTP client resilience defaults ---
HTTP_CLIENT_TIMEOUT_MS=5000
HTTP_CLIENT_MAX_RETRIES=3
HTTP_CLIENT_CIRCUIT_BREAKER_THRESHOLD=5

# --- Internal event bus (EDA, per BPP_details_v1.1.md §7) ---
EVENT_BUS_URL=redis://bpp-cache:6379/1
EVENT_BUS_DLQ_NAME=bpp-internal-dlq

# --- CORS (BPP web app origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:3001

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
