# Beckn Gateway — environment configuration template. Copy to .env and fill with real values (never commit .env).

# --- App ---
DJANGO_ENV=local
DJANGO_SECRET_KEY=changeme-generate-a-real-secret
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,beckn-gateway

# --- No database (Gateway is stateless per beckn_gateway_details_v1.1.md §4) ---

# --- Cache (on by default since livetracker2.md §3.11 — search now puts Gateway on
# continuous customer-facing traffic, so its Redis-backed circuit breaker needs to be
# active by default too, matching BAP/BPP's own unconditional Redis dependency) ---
CACHE_ENABLED=true
REDIS_URL=redis://gateway-cache:6379/0

# --- Registry client ---
REGISTRY_BASE_URL=http://registry:8000
REGISTRY_LOOKUP_TIMEOUT_MS=3000

# --- Gateway's own signing identity ---
GATEWAY_SIGNING_PRIVATE_KEY_PATH=/app/data/secrets/gateway_signing_key
GATEWAY_ENCRYPTION_PRIVATE_KEY_PATH=/app/data/secrets/gateway_encryption_key
# Note: when Gateway PROXIES another participant's transaction request (search ->
# on_search), it signs with X-Gateway-Authorization, not Authorization — see
# protocol_compliance_notes_v1.1.md §C.3/§H.3. Don't reuse BAP/BPP signing middleware
# unmodified for that path. Gateway's OWN Subscribe/Lookup calls below (Phase 3.3,
# registry.yaml paths) use Authorization like any other participant — see
# core/registry_client.py's module docstring for why these aren't the same thing.

# --- Gateway's own network identity (Phase 3.3 onboarding) ---
SUBSCRIBER_ID=changeme.gateway.example.com
UNIQUE_KEY_ID=changeme-uuid
# Gateway's own real, publicly reachable HTTPS URL — see BAP/backend/.env.example's
# SUBSCRIBER_URL comment for the full rationale (identical here).
SUBSCRIBER_URL=
ON_SUBSCRIBE_CALLBACK_PATH=/on_subscribe
# Gateway has no database (stateless per beckn_gateway_details_v1.1.md §4) — onboarding
# progress is tracked in this small JSON file instead of a DB table.
ONBOARDING_STATE_PATH=/app/data/onboarding_state.json

# --- Service domains this Gateway routes across (same three as BAP/BPP — see
# BPP/backend/.env.example for the full domain-code research trail) ---
DOMAIN_HEALTHCARE=CONFIRM_BEFORE_USE
DOMAIN_AUTOMOTIVE=CONFIRM_BEFORE_USE
DOMAIN_BEAUTY=ONDC:RET13

# --- HTTP client resilience defaults (per livetracker1.md Phase 1.2) ---
HTTP_CLIENT_TIMEOUT_MS=5000
HTTP_CLIENT_MAX_RETRIES=3
HTTP_CLIENT_CIRCUIT_BREAKER_THRESHOLD=5

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
