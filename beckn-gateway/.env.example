# Beckn Gateway — environment configuration template. Copy to .env and fill with real values (never commit .env).

# --- App ---
DJANGO_ENV=local
DJANGO_SECRET_KEY=changeme-generate-a-real-secret
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# --- No database (Gateway is stateless per beckn_gateway_details_v1.1.md §4) ---

# --- Cache (optional, [BETA] per livetracker1.md Phase 1.2 — for trusted Registry-key caching) ---
CACHE_ENABLED=false
REDIS_URL=redis://gateway-cache:6379/0

# --- Registry client ---
REGISTRY_BASE_URL=http://registry:8000
REGISTRY_LOOKUP_TIMEOUT_MS=3000

# --- Gateway's own signing identity ---
GATEWAY_SIGNING_PRIVATE_KEY_PATH=/run/secrets/gateway_signing_key
GATEWAY_ENCRYPTION_PRIVATE_KEY_PATH=/run/secrets/gateway_encryption_key
# Note: Gateway signs outbound calls with Proxy-Authorization, not Authorization —
# see protocol_compliance_notes_v1.1.md §C.3. Don't reuse BAP/BPP signing middleware unmodified.

# --- HTTP client resilience defaults (per livetracker1.md Phase 1.2) ---
HTTP_CLIENT_TIMEOUT_MS=5000
HTTP_CLIENT_MAX_RETRIES=3
HTTP_CLIENT_CIRCUIT_BREAKER_THRESHOLD=5

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
