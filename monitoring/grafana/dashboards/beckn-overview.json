{
  "title": "Beckn Platform — Overview",
  "uid": "beckn-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "app_uptime_seconds", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Registry — Subscribe Requests vs Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "registry_requests_total{metric=\"subscribe_requests_total\"}",
          "legendFormat": "subscribe_requests_total",
          "refId": "A"
        },
        {
          "expr": "registry_requests_total{metric=\"subscribe_errors_total\"}",
          "legendFormat": "subscribe_errors_total",
          "refId": "B"
        }
      ],
      "description": "Per RUNBOOK.md: a sudden spike in subscribe_errors_total suggests a misbehaving client or attack — investigate before assuming abuse."
    },
    {
      "id": 3,
      "title": "Registry — Lookup Requests vs Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "registry_requests_total{metric=\"lookup_requests_total\"}",
          "legendFormat": "lookup_requests_total",
          "refId": "A"
        },
        {
          "expr": "registry_requests_total{metric=\"lookup_errors_total\"}",
          "legendFormat": "lookup_errors_total",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Registry — on_subscribe Verify Successes vs Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "registry_requests_total{metric=\"verify_successes_total\"}",
          "legendFormat": "verify_successes_total",
          "refId": "A"
        },
        {
          "expr": "registry_requests_total{metric=\"verify_failures_total\"}",
          "legendFormat": "verify_failures_total",
          "refId": "B"
        }
      ],
      "description": "Per RUNBOOK.md: a large, persistent gap between verify_successes_total and subscribe_requests_total suggests participants are failing onboarding."
    },
    {
      "id": 5,
      "title": "Registry — Average Latency (subscribe vs lookup)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "registry_request_latency_seconds_sum{metric=\"subscribe\"} / registry_request_latency_seconds_count{metric=\"subscribe\"}",
          "legendFormat": "subscribe avg latency",
          "refId": "A"
        },
        {
          "expr": "registry_request_latency_seconds_sum{metric=\"lookup\"} / registry_request_latency_seconds_count{metric=\"lookup\"}",
          "legendFormat": "lookup avg latency",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "description": "No fixed alert threshold set yet (RUNBOOK.md) — no real traffic baseline exists at foundation stage. Watch for trend, not an absolute number."
    }
  ]
}
