# Registry — environment configuration template. Copy to .env and fill with real values (never commit .env).

# --- App ---
DJANGO_ENV=local                       # local | dev | staging | preprod | production
DJANGO_SECRET_KEY=changeme-generate-a-real-secret
DJANGO_DEBUG=true                      # must be false outside local/dev
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
DATABASE_URL=postgres://registry:registry@registry-db:5432/registry
DB_CONN_MAX_AGE=60
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# --- Registry's own signing identity (per protocol_compliance_notes_v1.1.md §A.5) ---
REGISTRY_SIGNING_PRIVATE_KEY_PATH=/run/secrets/registry_signing_key   # never inline the key value here
REGISTRY_ENCRYPTION_PRIVATE_KEY_PATH=/run/secrets/registry_encryption_key

# --- Rate limits (per protocol_compliance_notes_v1.1.md §B.6 — ONDC concrete values) ---
SUBSCRIBE_RATE_LIMIT_PER_MIN=10
LOOKUP_RATE_LIMIT_PER_MIN=7600

# --- Observability (per OBSERVABILITY.md) ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- CORS (registry is backend-only, called by other backends, not browsers) ---
CORS_ALLOWED_ORIGINS=
