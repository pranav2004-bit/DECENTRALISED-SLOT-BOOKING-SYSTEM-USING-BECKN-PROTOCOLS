{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ONDC Subscribe Request",
  "description": "Derived from protocol_compliance_notes_v1.1.md §B.3 — confirmed real ONDC Subscribe payload shape.",
  "type": "object",
  "required": ["context", "message"],
  "properties": {
    "context": {
      "type": "object",
      "required": ["operation"],
      "properties": {
        "operation": {
          "type": "object",
          "required": ["ops_no"],
          "properties": {
            "ops_no": { "type": "integer", "enum": [1, 2, 4] }
          }
        }
      }
    },
    "message": {
      "type": "object",
      "required": ["request_id", "timestamp", "entity", "network_participant"],
      "properties": {
        "request_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "entity": {
          "type": "object",
          "required": ["subscriber_id", "unique_key_id", "callback_url", "key_pair", "country"],
          "properties": {
            "subscriber_id": { "type": "string" },
            "unique_key_id": { "type": "string" },
            "callback_url": { "type": "string" },
            "country": { "type": "string" },
            "email_id": { "type": "string" },
            "mobile_no": { "type": "integer" },
            "key_pair": {
              "type": "object",
              "required": ["signing_public_key", "encryption_public_key", "valid_from", "valid_until"],
              "properties": {
                "signing_public_key": { "type": "string" },
                "encryption_public_key": { "type": "string" },
                "valid_from": { "type": "string", "format": "date-time" },
                "valid_until": { "type": "string", "format": "date-time" }
              }
            }
          }
        },
        "network_participant": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["subscriber_url", "domain", "type"],
            "properties": {
              "subscriber_url": { "type": "string" },
              "domain": { "type": "string" },
              "type": { "type": "string", "enum": ["buyerApp", "sellerApp", "gateway"] }
            }
          }
        }
      }
    }
  }
}
